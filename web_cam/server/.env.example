# ── Server .env.example ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.

# HTTP port for Express + Socket.IO
PORT=3001

# RTMP ingest port (camera box pushes here)
RTMP_PORT=1935

# Where ffmpeg writes HLS segments (must be writable)
HLS_PATH=/tmp/hls

# HLS fragment duration in seconds (lower = less latency, more CPU)
HLS_FRAGMENT_DURATION=2

# Number of HLS segments kept in playlist
HLS_PLAYLIST_LENGTH=6

# Optional: append this secret to stream keys for auth
# Camera pushes to rtmp://<host>/live/cam0_mysecret
# Leave empty to disable auth
STREAM_SECRET=

# Admin password for management API
ADMIN_PASSWORD=change_me_please

# Space-separated list of allowed CORS origins
# Your React frontend URL goes here
ALLOWED_ORIGINS=http://localhost:5173 https://your-app.vercel.app

# Path to ffmpeg binary (needed for HLS transcoding)
FFMPEG_PATH=/usr/bin/ffmpeg

NODE_ENV=production
