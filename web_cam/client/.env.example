# ── Client .env.example ───────────────────────────────────────
# Copy to .env (development) or .env.production (production build)
# All vars MUST start with VITE_ to be exposed to the browser.

# Your deployed backend URL
VITE_API_URL=http://localhost:3001

# Socket.IO server URL (usually same as API)
VITE_SOCKET_URL=http://localhost:3001

# App name shown in the header
VITE_APP_NAME=CamWatch
